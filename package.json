{
  "name": "@monots/monorepo",
  "private": true,
  "description": "The monorepo for managing your monots project",
  "repository": "https://github.com/monots/monots.git",
  "license": "MIT",
  "author": "Ifiok Jr.",
  "workspaces": [
    "@monots/*",
    "packages/*"
  ],
  "scripts": {
    "build:ts": "tsc -b tsconfig.build.json --verbose",
    "fix:es": "yarn run:lint:es --fix",
    "fix:prettier": "yarn run:prettier --write",
    "generate:ts": "yarn monots generate ts",
    "lint:es": "yarn run:lint:es",
    "lint:prettier": "yarn run:prettier --check",
    "monots": "yarn ts @monots/cli/src/cli",
    "run:lint:es": "eslint --ext=.tsx,.ts,.js .",
    "run:prettier": "prettier '**/*.{js,jsx,ts,tsx,md,json,html,css,yml,yaml,graphql}'",
    "ts": "ts-node --project='./tsconfig.node.json' --require=tsconfig-paths/register"
  },
  "prettier": "./packages/prettier-config-monots/index.js",
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "project": [
        "./tsconfig.json"
      ]
    },
    "extends": [
      "./packages/eslint-config-monots/index.js"
    ]
  },
  "eslintIgnore": [
    "**/lib",
    "lib",
    "**/dist",
    "dist",
    ".yarn/**",
    "node_modules",
    "coverage"
  ],
  "jest": {
    "preset": "./packages/jest-preset-monots"
  },
  "resolutions": {
    "@types/ink": "^2.0.3",
    "type-fest": ">=0.12.0"
  },
  "devDependencies": {
    "@babel/core": "^7.9.0",
    "@babel/plugin-proposal-class-properties": "^7.8.3",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.8.3",
    "@babel/plugin-proposal-object-rest-spread": "^7.9.5",
    "@babel/plugin-proposal-optional-chaining": "^7.9.0",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-runtime": "^7.9.0",
    "@babel/preset-env": "^7.9.5",
    "@babel/preset-react": "^7.9.4",
    "@changesets/cli": "^2.6.5",
    "@types/jest": "^25.2.1",
    "@types/node": "^13.13.1",
    "babel-jest": "^25.4.0",
    "danger": "^10.1.1",
    "eslint": "^6.8.0",
    "jest": "^25.4.0",
    "prettier": "^2.0.4",
    "ts-jest": "^25.4.0",
    "ts-node": "^8.9.0",
    "tsconfig-paths": "^3.9.0",
    "tslib": "^1.11.1",
    "typescript": "^3.8.3"
  },
  "engines": {
    "node": ">=10"
  },
  "monots": {
    "tsconfigBaseExtends": "./@monots/tsconfig/tsconfig.json"
  }
}
